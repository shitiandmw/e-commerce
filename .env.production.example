# ============================================================================
# 生产环境配置模板
# 复制为 .env.production 并填入实际值
# 用法: docker compose --env-file .env.production up --build -d
# ============================================================================

# ---- 端口映射（宿主机端口，可按需修改避免冲突） ----
POSTGRES_PORT=45432
REDIS_PORT=46379
MEDUSA_PORT=49000
SOCKET_PORT=49001
ADMIN_PORT=43002
STOREFRONT_PORT=43000
NGINX_PORT=40080

# ---- 数据库 ----
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=medusa_ecommerce

# ---- Medusa 后端 ----
JWT_SECRET=change_me_jwt_secret
COOKIE_SECRET=change_me_cookie_secret
# If the password contains @ : / ? # % &, URL-encode it in DATABASE_URL.
DATABASE_URL=postgres://medusa:change_me_to_a_strong_password@postgres:5432/medusa_ecommerce?sslmode=disable
REDIS_URL=redis://redis:6379

# CORS — 根据实际域名修改
STORE_CORS=http://localhost:43000
ADMIN_CORS=http://localhost:43002
AUTH_CORS=http://localhost:43002,http://localhost:43000

# Storefront 对外访问地址（用于密码重置邮件中的链接，不要带末尾斜杠）
STOREFRONT_URL=http://localhost:43000

# Gmail SMTP 密码重置邮件（SMTP_USER 和 SMTP_PASS 必须同时填写）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SendGrid 备用配置（三项必须同时填写；SMTP 配置优先）
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=

# Stripe（可选）
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# WooshPay（可选）
# true/未设置: 注册 WooshPay provider；false: 不注册该 provider
WOOSHPAY_ENABLED=true
# WooshPay API key 和 webhook secret 在 Admin UI 的支付配置中设置。
# 当前 provider 从 runtime payment settings 读取，不读取 WOOSHPAY_API_KEY/WOOSHPAY_WEBHOOK_SECRET。

# ---- Socket.io 与 AI 客服 ----
# Socket.io 服务端口（与 SOCKET_PORT 保持一致）
SOCKET_PORT=49001

# AI 服务配置（客服 AI 托管功能）
# 支持的 AI 提供商: openai, anthropic
AI_PROVIDER=openai
# OpenAI API Key（如使用 OpenAI）
AI_API_KEY=
# 自定义 API URL（可选，用于兼容 OpenAI 的第三方服务）
AI_API_URL=
# AI 模型名称（如 gpt-4o-mini, claude-3-5-sonnet-20241022）
AI_MODEL=gpt-4o-mini

# ---- 前端构建参数 ----
# Admin UI 访问后端的地址（浏览器端，需要是用户可访问的地址）
NEXT_PUBLIC_MEDUSA_BACKEND_URL_ADMIN=http://localhost:49000
# Storefront 访问后端的地址
NEXT_PUBLIC_MEDUSA_BACKEND_URL_STORE=http://localhost:49000
# Storefront Publishable API Key
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Socket.io 客户端连接地址（浏览器端，用于客服聊天功能）
NEXT_PUBLIC_SOCKET_URL=http://localhost:49001

# ---- Nginx 域名（仅 with-nginx profile 使用） ----
STORE_DOMAIN=store.example.com
ADMIN_DOMAIN=admin.example.com
API_DOMAIN=api.example.com
